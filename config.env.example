#
# Copy to config.env and adjust for the target machine before running the installer.
# The installer loads this file automatically when present.
#

# Required
export ANYPWD="change-me"

# Optional system/user settings
export WS_USER="${SUDO_USER:-weather}"
export INSTALL_DIR="\$HOME/weather-initialization"
export VANTAGE_PUBLISHER_DIR="\$HOME/vantage-publisher"

# Optional hotspot settings
export HOTSPOT_CONNECTION_NAME="Weather"
export HOTSPOT_SSID="weather-parthenope"
export HOTSPOT_BAND="bg"
export HOTSPOT_CHANNEL="11"

# Optional VPN/network settings
export VPN_CONNECTION_NAME=""
export CONNECTIVITY_HOST="8.8.8.8"

# Optional serial/archive settings
export WEATHER_DEVICE_URL="tcp:127.0.0.1:22222"
export WEATHER_SERIAL_DEVICE="/dev/ttyUSB0"
export STORAGE_GROUP="vantagepro"
export STORAGE_DIR="/storage"

# Optional SSH keys file. One public key per line.
# export AUTHORIZED_KEYS_FILE="\$HOME/weather-initialization/authorized_keys"
